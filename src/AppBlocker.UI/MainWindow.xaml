<Window x:Class="AppBlocker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AppBlocker.UI.ViewModels"
        xmlns:views="clr-namespace:AppBlocker.UI.Views"
        Title="AppBlocker - Фокус и Продуктивность" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#18181B" 
        Foreground="#E4E4E7"
        FontFamily="Segoe UI"
        MouseMove="Window_InputActivity"
        KeyDown="Window_InputActivity"
        Activated="Window_Activated">

    <!-- Привязка главного ViewModel к окну -->
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <!-- Словарь DataTemplate: WPF автоматически подставит нужный View для каждого ViewModel -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:DopamineMenuViewModel}">
            <views:DopamineMenuView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:BlacklistsViewModel}">
            <views:BlacklistsView />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Общий стиль кнопок бокового меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A1A1AA"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10,5">
                            <ContentPresenter Margin="{TemplateBinding Padding}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27272A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" /> <!-- Боковая панель -->
            <ColumnDefinition Width="*" />   <!-- Основной контент -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#09090B" BorderBrush="#27272A" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,30,0,0">
                <TextBlock Text="AppBlocker" FontSize="28" FontWeight="Bold" Foreground="White" Margin="30,0,0,40"/>

                <!-- Навигация с привязкой к командам из MainViewModel -->
                <Button Content="Дашборд" Command="{Binding NavigateDashboardCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Черные списки" Command="{Binding NavigateBlacklistsCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Дофаминовое меню" Command="{Binding NavigateDopamineCommand}" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="Настройки" Command="{Binding NavigateSettingsCommand}" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- ContentControl: Сюда WPF подставит DashboardView.xaml, если CurrentViewModel == DashboardViewModel и т.д. -->
        <ContentControl x:Name="MainContent" Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="40" />

        <!-- Overlay блокировки приложения -->
        <Border x:Name="LockOverlay" Grid.ColumnSpan="2" Background="#E609090B" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔒" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="Приложение заблокировано" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Доступ ограничен для вашей безопасности" FontSize="14" Foreground="#A1A1AA" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                <Button Content="Разблокировать" Click="UnlockBtn_Click"
                        Background="#3B82F6" Foreground="White" FontSize="16" FontWeight="SemiBold"
                        Padding="30,12" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
