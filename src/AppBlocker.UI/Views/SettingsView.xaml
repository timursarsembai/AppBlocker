<UserControl x:Class="AppBlocker.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AppBlocker.UI.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        
        <!-- Стиль для секций настроек -->
        <Style x:Key="SettingCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#27272A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25,20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Стиль для числовых полей ввода -->
        <Style x:Key="NumberInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Настройки" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <TextBlock Text="Конфигурация приложения и таймеров" FontSize="14" Foreground="#A1A1AA" Margin="0,0,0,30"/>

            <!-- Секция: Основные -->
            <TextBlock Text="О С Н О В Н Ы Е" FontSize="13" FontWeight="SemiBold" Foreground="#71717A" Margin="0,0,0,12"/>

            <Border Style="{StaticResource SettingCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Автозагрузка" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Запускать AppBlocker вместе с Windows" FontSize="13" Foreground="#A1A1AA" Margin="0,5,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding AutoStartUI}" VerticalAlignment="Center">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                </Grid>
            </Border>

            <Border Style="{StaticResource SettingCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Сворачивать в трей" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Не закрывать приложение, а сворачивать в системный трей" FontSize="13" Foreground="#A1A1AA" Margin="0,5,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding MinimizeToTray}" VerticalAlignment="Center">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                </Grid>
            </Border>

            <!-- Секция длительности удалена, так как время задается напрямую в дашборде -->

            <!-- Секция: Защита -->
            <TextBlock Text="З А Щ И Т А   О Т   О Т К Л Ю Ч Е Н И Я" FontSize="13" FontWeight="SemiBold" Foreground="#71717A" Margin="0,20,0,12"/>

            <Border Style="{StaticResource SettingCardStyle}">
                <StackPanel>
                    <TextBlock Text="Метод защиты" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Запрашивать при попытке досрочно остановить сессию блокировки" FontSize="13" Foreground="#A1A1AA" Margin="0,5,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <RadioButton Content="Нет" IsChecked="{Binding IsProtectionNone}" Foreground="White" Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <RadioButton Content="PIN-код" IsChecked="{Binding IsProtectionPin}" Foreground="White" Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <RadioButton Content="Пароль" IsChecked="{Binding IsProtectionPassword}" Foreground="White" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <Grid Visibility="{Binding IsProtectionNone, Converter={StaticResource InverseBooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox x:Name="ProtectionInput" Background="#18181B" Foreground="White" BorderBrush="#3F3F46" 
                                     BorderThickness="1" Padding="10,8" FontSize="16" Grid.Column="0" Margin="0,0,10,0"/>
                        <Button Content="Установить" Background="#3F3F46" Foreground="White" BorderThickness="0" Padding="15,8" Grid.Column="1" Cursor="Hand" Click="SetProtectionBtn_Click"/>
                    </Grid>

                    <CheckBox Content="Требовать решение математической задачи (дополнительно)" 
                              IsChecked="{Binding RequireMathChallenge}" 
                              Foreground="White" Margin="0,20,0,0" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Кнопка сброса -->
            <Button Content="Сбросить настройки по умолчанию" Command="{Binding ResetSettingsCommand}"
                    Background="#3F3F46" Foreground="#A1A1AA" FontSize="14"
                    BorderThickness="0" Padding="20,12" Margin="0,20,0,0"
                    HorizontalAlignment="Left" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btn" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btn" Property="Background" Value="#52525B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </ScrollViewer>
</UserControl>
