<UserControl x:Class="AppBlocker.UI.Views.BlacklistsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="TableActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="actionBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="actionBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,10"/>
        </Style>

        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,12"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent" 
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D4D4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Черные списки" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,25"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- ===== ВКЛАДКА 1: Заблокированные ресурсы ===== -->
            <TabItem Header="🔒  Заблокированные">
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель добавления сайта -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0" Text="{Binding NewWebsiteText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#18181B" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1" 
                                 Padding="15,10" FontSize="15"
                                 ToolTip="Домен (mail.ru) или путь (youtube.com/shorts)"/>
                        
                        <ComboBox Grid.Column="1" SelectedItem="{Binding NewWebsiteType}" 
                                  Background="#18181B" Foreground="White" BorderBrush="#3F3F46" Margin="10,0,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="White"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <TextBox Grid.Column="2" Text="{Binding NewWebsiteStartTime}" 
                                 Background="#18181B" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1" 
                                 Padding="10,10" FontSize="15" Margin="10,0,0,0" ToolTip="От (ЧЧ:ММ)"/>
                        
                        <TextBox Grid.Column="3" Text="{Binding NewWebsiteEndTime}" 
                                 Background="#18181B" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1" 
                                 Padding="10,10" FontSize="15" Margin="10,0,0,0" ToolTip="До (ЧЧ:ММ)"/>

                        <Button Grid.Column="4" Content="+ Добавить" Command="{Binding AddWebsiteCommand}"
                                Background="#3B82F6" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                Style="{StaticResource TableActionButton}" Margin="10,0,0,0" Padding="20,10"/>
                    </Grid>

                    <!-- Заголовки таблиц и списки -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            
                            <!-- 1. ВСЕГДА -->
                            <TextBlock Text="🔒 ЗАБЛОКИРОВАНЫ ВСЕГДА" FontSize="14" FontWeight="SemiBold" Foreground="#EF4444" Margin="0,0,0,10"/>
                            <Border Background="#1E1E22" CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="РЕСУРС" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="1" Text="ТИП" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="2" Text="ДЕЙСТВИЕ" Style="{StaticResource HeaderText}"/>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding AlwaysBlocked}" Margin="0,0,0,30">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource CellText}"/>
                                                <TextBlock Grid.Column="1" Text="Всегда" Foreground="#EF4444" Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                                <Button Grid.Column="2" Content="Удалить" 
                                                        Background="#451A1E" Foreground="#F87171"
                                                        Style="{StaticResource TableActionButton}" Margin="10,6"
                                                        Command="{Binding DataContext.RemoveWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 2. ПО ТАЙМЕРУ -->
                            <TextBlock Text="⏱️ ЗАБЛОКИРОВАНЫ ВО ВРЕМЯ СЕССИЙ" FontSize="14" FontWeight="SemiBold" Foreground="#60A5FA" Margin="0,0,0,10"/>
                            <Border Background="#1E1E22" CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="РЕСУРС" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="1" Text="ТИП" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="2" Text="ДЕЙСТВИЕ" Style="{StaticResource HeaderText}"/>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding TimerBlocked}" Margin="0,0,0,30">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource CellText}"/>
                                                <TextBlock Grid.Column="1" Text="По таймеру" Foreground="#60A5FA" Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                                <Button Grid.Column="2" Content="Удалить" 
                                                        Background="#451A1E" Foreground="#F87171"
                                                        Style="{StaticResource TableActionButton}" Margin="10,6"
                                                        Command="{Binding DataContext.RemoveWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 3. ПО РАСПИСАНИЮ -->
                            <TextBlock Text="📅 ЗАБЛОКИРОВАНЫ ПО РАСПИСАНИЮ" FontSize="14" FontWeight="SemiBold" Foreground="#34D399" Margin="0,0,0,10"/>
                            <Border Background="#1E1E22" CornerRadius="8,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="РЕСУРС" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="1" Text="ТИП" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="2" Text="ВРЕМЯ" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Grid.Column="3" Text="ДЕЙСТВИЕ" Style="{StaticResource HeaderText}"/>
                                </Grid>
                            </Border>
                            <ItemsControl ItemsSource="{Binding ScheduleBlocked}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="120"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource CellText}"/>
                                                <TextBlock Grid.Column="1" Text="По расписанию" Foreground="#34D399" Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                                    <TextBlock Text="{Binding StartTime, StringFormat=\{0:hh\\:mm\}}" Foreground="White"/>
                                                    <TextBlock Text=" - " Foreground="White"/>
                                                    <TextBlock Text="{Binding EndTime, StringFormat=\{0:hh\\:mm\}}" Foreground="White"/>
                                                </StackPanel>
                                                <Button Grid.Column="3" Content="Удалить" 
                                                        Background="#451A1E" Foreground="#F87171"
                                                        Style="{StaticResource TableActionButton}" Margin="10,6"
                                                        Command="{Binding DataContext.RemoveWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===== ВКЛАДКА 2: Процессы ОС (для выбора) ===== -->
            <TabItem Header="⚙️  Активные процессы">
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="ЗАПУЩЕННЫЕ ПРОЦЕССЫ" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#71717A" VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#18181B" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1"
                                 Padding="10,8" FontSize="14" Margin="20,0,10,0">
                        </TextBox>

                        <Button Grid.Column="2" Content="⟳ Обновить" 
                                Command="{Binding RefreshProcessesCommand}"
                                Background="#3F3F46" Foreground="#D4D4D8" FontSize="13"
                                Style="{StaticResource TableActionButton}" Padding="16,8"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredProcesses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0" Width="10" Height="10" 
                                                     Fill="#34D399" Margin="10,0,0,0"/>

                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding FileName}" Style="{StaticResource CellText}" Foreground="#A1A1AA"/>
                                            
                                            <Button Grid.Column="3" Content="Заблокировать" Margin="10,6"
                                                    Command="{Binding DataContext.ToggleBlockProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource TableActionButton}">
                                                        <Setter Property="Background" Value="#451A1E"/>
                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
