<UserControl x:Class="AppBlocker.UI.Views.BlacklistsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="TableActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="actionBorder" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="actionBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,10"/>
        </Style>

        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,12"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#71717A"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent" 
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D4D4D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Черные списки" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,25"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" 
                    SelectedIndex="{Binding SelectedTab}">

            <!-- ===== ВКЛАДКА 1: Веб-сайты ===== -->
            <TabItem Header="&#x1F310;  Веб-сайты">
                <Grid Margin="0,25,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewWebsiteText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#18181B" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1" 
                                 Padding="15,10" FontSize="15"
                                 ToolTip="Домен (mail.ru) или путь (youtube.com/shorts)"/>
                        <Button Grid.Column="1" Content="+ Добавить сайт" Command="{Binding AddWebsiteCommand}"
                                Background="#3B82F6" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                Style="{StaticResource TableActionButton}" Margin="10,0,0,0" Padding="20,10"/>
                    </Grid>

                    <Border Grid.Row="1" Background="#1E1E22" CornerRadius="8,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="URL АДРЕС" Style="{StaticResource HeaderText}"/>
                            <TextBlock Grid.Column="1" Text="СТАТУС" Style="{StaticResource HeaderText}"/>
                            <TextBlock Grid.Column="2" Text="ДЕЙСТВИЕ" Style="{StaticResource HeaderText}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BlockedWebsites}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Url}" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding StatusColor}" 
                                                       Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                            <Button Grid.Column="2" Content="Удалить" 
                                                    Background="#451A1E" Foreground="#F87171"
                                                    Style="{StaticResource TableActionButton}" Margin="10,6"
                                                    Command="{Binding DataContext.RemoveWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ===== ВКЛАДКА 2: Процессы ОС ===== -->
            <TabItem Header="&#x2699;  Процессы ОС">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                    <StackPanel>

                        <!-- Верхняя часть: Заблокированные процессы -->
                        <TextBlock Text="ЗАБЛОКИРОВАННЫЕ" FontSize="13" FontWeight="SemiBold" Foreground="#71717A" Margin="0,0,0,10"/>

                        <Border Background="#1E1E22" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="1" Text="ПРИЛОЖЕНИЕ" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="2" Text="ФАЙЛ ПРОЦЕССА" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="3" Text="СОСТОЯНИЕ" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="4" Text="ДЕЙСТВИЕ" Style="{StaticResource HeaderText}"/>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding BlockedProcesses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1" 
                                            Opacity="{Binding RowOpacity}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Индикатор запущен/не запущен -->
                                            <Ellipse Grid.Column="0" Width="10" Height="10" 
                                                     Fill="{Binding IndicatorColor}" Margin="10,0,0,0"/>

                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding FileName}" Style="{StaticResource CellText}" Foreground="#A1A1AA"/>
                                            <TextBlock Grid.Column="3" Text="{Binding StatusText}" Foreground="{Binding StatusColor}" 
                                                       Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                            
                                            <Button Grid.Column="4" Content="Разблокировать" Margin="10,6"
                                                    Command="{Binding DataContext.UnblockProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource TableActionButton}">
                                                        <Setter Property="Background" Value="#14532D"/>
                                                        <Setter Property="Foreground" Value="#34D399"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Текст если пусто -->
                        <TextBlock Text="Нет заблокированных процессов" 
                                   Foreground="#52525B" FontSize="14" FontStyle="Italic"
                                   Margin="15,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BlockedProcesses.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Нижняя часть: Все запущенные процессы -->
                        <Grid Margin="0,30,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="ВСЕ ПРОЦЕССЫ" FontSize="13" FontWeight="SemiBold" 
                                       Foreground="#71717A" VerticalAlignment="Center"/>

                            <!-- Поиск -->
                            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="#18181B" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1"
                                     Padding="10,8" FontSize="14" Margin="20,0,10,0">
                            </TextBox>

                            <Button Grid.Column="2" Content="&#x27F3;  Обновить" 
                                    Command="{Binding RefreshProcessesCommand}"
                                    Background="#3F3F46" Foreground="#D4D4D8" FontSize="13"
                                    Style="{StaticResource TableActionButton}" Padding="16,8"/>
                        </Grid>

                        <Border Background="#1E1E22" CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="1" Text="ПРИЛОЖЕНИЕ" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="2" Text="ФАЙЛ ПРОЦЕССА" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="3" Text="СОСТОЯНИЕ" Style="{StaticResource HeaderText}"/>
                                <TextBlock Grid.Column="4" Text="ДЕЙСТВИЕ" Style="{StaticResource HeaderText}"/>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding FilteredProcesses}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#27272A" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0" Width="10" Height="10" 
                                                     Fill="#34D399" Margin="10,0,0,0"/>

                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding FileName}" Style="{StaticResource CellText}" Foreground="#A1A1AA"/>
                                            <TextBlock Grid.Column="3" Text="Активен" Foreground="#34D399" 
                                                       Style="{StaticResource CellText}" FontWeight="SemiBold"/>
                                            
                                            <Button Grid.Column="4" Content="Заблокировать" Margin="10,6"
                                                    Command="{Binding DataContext.ToggleBlockProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource TableActionButton}">
                                                        <Setter Property="Background" Value="#451A1E"/>
                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
