<Window x:Class="AppBlocker.UI.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="250" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#18181B" CornerRadius="12" BorderBrush="#3F3F46" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="Защита от отключения" FontSize="18" FontWeight="Bold" Foreground="White" Grid.Row="0" Margin="0,0,0,20"/>

            <!-- Стадия ввода пароля/PIN (показывается только если IsAuthStage=True) -->
            <StackPanel Grid.Row="1" Visibility="{Binding IsAuthStage, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding PromptText}" Foreground="#A1A1AA" FontSize="14" Margin="0,0,0,10"/>
                <PasswordBox x:Name="PasswordInput" Background="#27272A" Foreground="White" BorderBrush="#3F3F46" 
                             BorderThickness="1" Padding="10" FontSize="16" KeyDown="Input_KeyDown"/>
            </StackPanel>

            <!-- Стадия математики (показывается только если IsMathStage=True) -->
            <StackPanel Grid.Row="1" Visibility="{Binding IsMathStage, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Решите задачу для подтверждения:" Foreground="#A1A1AA" FontSize="14" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding MathProblem}" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBox Text="{Binding MathAnswerInput, UpdateSourceTrigger=PropertyChanged}" Background="#27272A" Foreground="White" BorderBrush="#3F3F46" 
                         BorderThickness="1" Padding="10" FontSize="16" HorizontalContentAlignment="Center" KeyDown="Input_KeyDown"/>
            </StackPanel>

            <!-- Ошибка -->
            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="#EF4444" FontSize="13" Margin="0,10,0,0" 
                       TextWrapping="Wrap" HorizontalAlignment="Center"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Command="{Binding CancelCommand}" Background="Transparent" Foreground="#A1A1AA" 
                        BorderThickness="0" Padding="15,8" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="Подтвердить" Command="{Binding SubmitCommand}" CommandParameter="{Binding ElementName=PasswordInput, Path=Password}"
                        Background="#3B82F6" Foreground="White" BorderThickness="0" Padding="20,8" Cursor="Hand" Click="Submit_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
