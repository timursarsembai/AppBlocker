<Window x:Class="AppBlocker.UI.Views.LowFrictionUnlockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AppBlocker.UI.ViewModels"
        Title="Снятие блокировки (Low-Friction)" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:LowFrictionUnlockViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"
                   Text="Вы действительно хотите сдаться?" Foreground="#333333"/>
        
        <TextBlock Grid.Row="1" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20" Foreground="#555555">
            Для досрочного отключения блокировки в режиме "Снижение барьера" необходимо вручную перепечатать следующий текст. Копирование и вставка отключены.
        </TextBlock>

        <!-- Строка для перепечатывания. Текст можно выделить, но в поле ввода его не вставить -->
        <Border Grid.Row="2" Background="#F5F6FA" BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="{Binding ChallengeString}" 
                       FontFamily="Consolas" 
                       FontSize="20" 
                       TextWrapping="Wrap" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#2F3640"/>
        </Border>

        <!-- Поле ввода с заблокированной вставкой -->
        <!-- ContextMenu="{x:Null}" отключает меню по правому клику (где есть кнопка Paste) -->
        <TextBox Grid.Row="3" 
                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" 
                 FontFamily="Consolas" 
                 FontSize="20" 
                 Height="120"
                 TextWrapping="Wrap" 
                 AcceptsReturn="True"
                 ContextMenu="{x:Null}"
                 DataObject.Pasting="TextBox_Pasting"
                 Margin="0,0,0,20"
                 Padding="10">
            <TextBox.InputBindings>
                <!-- Блокируем Ctrl+V и Shift+Insert на уровне горячих клавиш -->
                <KeyBinding Command="ApplicationCommands.NotACommand" Key="V" Modifiers="Control"/>
                <KeyBinding Command="ApplicationCommands.NotACommand" Key="Insert" Modifiers="Shift"/>
            </TextBox.InputBindings>
        </TextBox>

        <!-- Кнопка разблокировки -->
        <Button Grid.Row="4" 
                Content="СНЯТЬ БЛОКИРОВКУ" 
                Height="45" 
                FontSize="16"
                FontWeight="Bold"
                Background="#E74C3C" 
                Foreground="White"
                BorderThickness="0"
                Command="{Binding UnlockCommand}" 
                IsEnabled="{Binding IsUnlockSuccessful}">
            <Button.Style>
                <Style TargetType="Button">
                    <!-- Меняем прозрачность, когда кнопка неактивна (строка не совпала) -->
                    <Style.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
